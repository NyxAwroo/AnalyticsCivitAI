{
  "manifest_version": 3,
  "name": "AnalyticsCivitAI",
  "description": "Analyse locale des modèles, articles et tendances CivitAI.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "AnalyticsCivitAI",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["alarms", "storage", "identity", "notifications", "activeTab", "tabs"],
  "host_permissions": ["https://civitai.com/*"],
  "content_scripts": [
    {
      "matches": ["https://civitai.com/models/*"],
      "js": ["src/content/civitai-inject.ts"],
      "run_at": "document_idle"
    }
  ]
}
